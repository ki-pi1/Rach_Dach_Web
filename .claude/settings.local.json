{
  "permissions": {
    "allow": [
      "WebFetch(domain:21st.dev)",
      "Bash(npm create:*)",
      "Bash(npx sv:*)",
      "Bash(npm install:*)",
      "Bash(npx tailwindcss:*)",
      "Bash(winget install:*)",
      "Bash(gh auth:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs npx prettier --write"
          }
        ]
      }
    ]
  }
}
